# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same vars in your host
# (Netlify/Vercel → Environment variables). NEVER commit real secrets.
#
# This repo is the FundVella funnel (Next.js) + a thin capture backend: leads are
# captured, scored, and emitted as signed events to n8n (the automation brain),
# which writes the system-of-record to Supabase and a thin deal to HubSpot. The
# site itself never holds a CRM token — n8n does.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL — used for canonical tags, OpenGraph, sitemap, robots.
# Set this to the real production URL before the first build.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── cal.com booking (optional) ───────────────────────────────────────────────
# Booking handle (e.g. "fundvella/discover-call") or a full cal.com URL.
NEXT_PUBLIC_CALCOM_LINK=

# ── Analytics (optional; fall back to lib/site.ts if unset) ──────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_CLARITY_ID=

# ── Address autocomplete (optional; falls back to manual address fields) ─────
# Geoapify key for the one-line address autocomplete on the /apply form. If
# unset (or the request fails), the form gracefully renders the four manual
# street/city/state/zip fields instead. Free key at https://myprojects.geoapify.com
NEXT_PUBLIC_GEOAPIFY_KEY=

# Optional: restrict a deployment to a single vertical so the SAME repo can power
# a dedicated domain. Leave empty to serve all routes.
SITE_VERTICAL=

# ── Deep application (/apply/[vertical]) backend ─────────────────────────────
# Encrypts the SSN at rest (AES-256-GCM). 32-byte key as 64-char hex or base64,
# or any passphrase (stretched with scrypt). If UNSET, the SSN is used only for
# the immediate hand-off and is never stored. Generate: openssl rand -hex 32
APPLICATION_ENC_KEY=

# Where domain events (lead.captured, application.submitted/abandoned) are sent —
# the n8n webhook URL. Events carry a SAFE summary only (last-4 SSN, never raw).
# If unset, events are written to a dead-letter Blobs store and can be replayed.
APPLICATION_WEBHOOK_URL=

# Shared secret used to HMAC-sign those events (header x-fundvella-signature: v1=...).
# n8n recomputes it to reject forged/replayed events. Generate: openssl rand -hex 32
NURTURE_SECRET=

# Application persistence + bank-statement storage. Server-side only — do NOT
# prefix with NEXT_PUBLIC. If unset, resume uses Netlify Blobs automatically
# (cross-device, zero config on a Netlify deploy). Set these to use Supabase
# instead (service role required — the publishable/anon key cannot bypass RLS).
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STATEMENTS_BUCKET=bank-statements

# ── Resume / recovery emails (magic-link) ────────────────────────────────────
# "Finish your application" emails sent from funding@fundvella.com. Set a Resend
# key to send directly, OR leave blank to route the recovery event through
# APPLICATION_WEBHOOK_URL (n8n) and send/sequence the nudges there.
RESEND_API_KEY=
RESUME_EMAIL_FROM=FundVella <funding@fundvella.com>
NEXT_PUBLIC_CONTACT_EMAIL=funding@fundvella.com

# ── Plaid bank-link (optional; falls back to file upload) ────────────────────
# Lets a lead connect their bank read-only instead of uploading statements.
# Sandbox keys are free at dashboard.plaid.com. Server-side only.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
