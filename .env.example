# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same vars in Netlify
# (Site settings → Environment variables). NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# HubSpot Private App token (server-side only — never exposed to the browser).
# HubSpot → Settings → Integrations → Private Apps → your app → Auth.
# Scopes required: crm.objects.contacts.read/write, crm.objects.companies.read/write,
# crm.objects.deals.read/write.
HUBSPOT_PRIVATE_APP_TOKEN=

# Your HubSpot account/portal id (used in links/logging; optional for the API).
HUBSPOT_PORTAL_ID=

# Optional: a HubSpot Form GUID if you also want to mirror submissions into a
# HubSpot Form (not required for the server-side object API path).
HUBSPOT_FORM_ID=

# The MCA deal pipeline + default stage that new deals land in.
# Defaults below match the existing HubSpot "Sales Pipeline". After you build the
# 18-stage MCA pipeline (see README), paste its internal ids here.
HUBSPOT_DEAL_PIPELINE_ID=default
HUBSPOT_DEAL_DEFAULT_STAGE_ID=appointmentscheduled

# Public site URL (used for canonical tags, OpenGraph, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional (Option C upgrade): restrict a deployment to a single vertical so the
# SAME repo can power a dedicated domain. Leave empty to serve all 12 routes.
SITE_VERTICAL=
