# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same vars in Netlify
# (Site settings → Environment variables). NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# HubSpot Private App token (server-side only — never exposed to the browser).
# HubSpot → Settings → Integrations → Private Apps → your app → Auth.
# Scopes required: crm.objects.contacts.read/write, crm.objects.companies.read/write,
# crm.objects.deals.read/write.
HUBSPOT_PRIVATE_APP_TOKEN=

# Your HubSpot account/portal id (used in links/logging; optional for the API).
HUBSPOT_PORTAL_ID=

# Optional: a HubSpot Form GUID if you also want to mirror submissions into a
# HubSpot Form (not required for the server-side object API path).
HUBSPOT_FORM_ID=

# The MCA deal pipeline + default stage that new deals land in.
# Defaults below match the existing HubSpot "Sales Pipeline". After you build the
# 18-stage MCA pipeline (see README), paste its internal ids here.
HUBSPOT_DEAL_PIPELINE_ID=default
HUBSPOT_DEAL_DEFAULT_STAGE_ID=5498908918

# Set to "true" once the lifecycle + consent properties exist in HubSpot so the
# integration writes captured_at / lead_capture_stage / consent proof.
HUBSPOT_WRITE_LIFECYCLE=

# Public site URL (used for canonical tags, OpenGraph, sitemap, robots).
# Set this to the real production URL before the first build.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Resend) + nurture engine ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=FundVella <funding@fundvella.com>
# Shared secret that gates POST /api/nurture/run (also signs unsubscribe tokens).
NURTURE_SECRET=
# CAN-SPAM: a real physical mailing address, rendered in every nurture email.
BUSINESS_ADDRESS=
# Where "promising cold lead" alerts go (the SDR). Without it, escalations are silent.
SDR_ALERT_EMAIL=
# Cold-lead triage tuning (optional; defaults shown).
NURTURE_PROMISING_MIN=20
NURTURE_DISQUALIFY_DAYS=25
NURTURE_DELETE_IRRELEVANT=

# ── cal.com booking ─────────────────────────────────────────────────────────
# Booking handle (e.g. "fundvella-specialist/discover-call") or a full cal.com URL.
NEXT_PUBLIC_CALCOM_LINK=

# ── Analytics (optional; fall back to lib/site.ts if unset) ──────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_CLARITY_ID=

# Optional (Option C upgrade): restrict a deployment to a single vertical so the
# SAME repo can power a dedicated domain. Leave empty to serve all 12 routes.
SITE_VERTICAL=
