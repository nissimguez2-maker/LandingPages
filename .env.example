# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local dev, and set the same vars in your host
# (Netlify/Vercel → Environment variables). NEVER commit real secrets.
#
# This repo is the LANDING PAGE (front end) only. There is NO backend wired yet —
# you'll build that from scratch (the form POSTs to a placeholder app/api/lead).
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL — used for canonical tags, OpenGraph, sitemap, robots.
# Set this to the real production URL before the first build.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── cal.com booking (optional) ───────────────────────────────────────────────
# Booking handle (e.g. "fundvella/discover-call") or a full cal.com URL.
NEXT_PUBLIC_CALCOM_LINK=

# ── Analytics (optional; fall back to lib/site.ts if unset) ──────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_CLARITY_ID=

# Optional: restrict a deployment to a single vertical so the SAME repo can power
# a dedicated domain. Leave empty to serve all routes.
SITE_VERTICAL=

# ── Deep application (/apply/[vertical]) backend ─────────────────────────────
# Encrypts the SSN at rest (AES-256-GCM). 32-byte key as 64-char hex or base64,
# or any passphrase (stretched with scrypt). If UNSET, the SSN is used only for
# the immediate hand-off and is never stored. Generate: openssl rand -hex 32
APPLICATION_ENC_KEY=

# Where a completed application is forwarded (n8n / CRM webhook). Receives a SAFE
# summary only: last-4 of the SSN, never the raw number or the signature image.
APPLICATION_WEBHOOK_URL=

# Bank-statement uploads use Supabase Storage signed URLs into a PRIVATE bucket.
# Wire these to enable browser->bucket uploads; until then files are collected by
# a specialist. Server-side only — do NOT prefix with NEXT_PUBLIC.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STATEMENTS_BUCKET=bank-statements
